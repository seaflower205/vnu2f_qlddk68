      <Option name="dataDefinedScalebarSegmentWidth" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=1000 then 0.01&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=2000 then 0.02&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=5000 then 0.05&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=10000 then 0.1&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=25000 then 0.5&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=50000 then 1&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=100000 then 2&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=250000 then 5&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=500000 then 10&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=1000000 then 20&#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=2000000 then 50&#xa;else 100&#xa;end"/>
       <Option name="type" type="int" value="3"/>
      </Option>
