       <Option name="expression" type="QString" value="case when @project_crs = 'EPSG:4326' then 100 else 0 end"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedPositionX" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case &#xa;&#x9;when @layout_pagewidth &lt;=420 then (@layout_pagewidth/3)*2&#xa;&#x9;when @layout_pagewidth >420 then @layout_pagewidth/2 --x&#xa;end --vi du"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedPositionY" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;= 62370 then @layout_pageheight- 14.5 --A4&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=124740 then @layout_pageheight- 12-- A3&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=249480 then @layout_pageheight - 18 --A2&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=499554 then @layout_pageheight - 16 --A1&#xa;&#x9;&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=999949 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;100000 then @layout_pageheight - 23&#xa;&#x9;&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight >=999949 and &#xa;&#x9;round(map_get(item_variables('Map'), 'map_scale'),0) >=100000 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=250000 then @layout_pageheight - 23&#xa;&#x9;&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight >=999949 and &#xa;&#x9;round(map_get(item_variables('Map'), 'map_scale'),0) >=250000 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;1000000 then @layout_pageheight - 17&#xa;else @layout_pageheight-17&#xa;&#x9;&#xa;&#x9; &#xa;end&#xa;&#xa;--A0 và &lt;=&#x9; 100,000 &#x9;5&#xa;--A0 và >=&#x9; 250,000 &#x9;6&#xa;--A0 và >=&#x9; 1,000,000 &#x9;7"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedScaleBarRightSegments" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case&#xa;when @layout_pagewidth &lt;= 148 then 2&#xa;when @layout_pagewidth &lt;= 210 then 3&#xa;when @layout_pagewidth &lt;= 297 then 4&#xa;when @layout_pagewidth &lt;= 420 then 5&#xa;else 5&#xa;end"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedScalebarHeight" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="1.3"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedScalebarMaxWidth" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case &#xa;&#x9;when  @layout_pagewidth &lt;= 148 then 10 --A5&#xa;&#x9;when  @layout_pagewidth &lt;=210 then 30 -- A4 &#xa;&#x9;when  @layout_pagewidth &lt;=297 then 50 -- A3 &#xa;&#x9;else 107&#xa;end"/>
       <Option name="type" type="int" value="3"/>
      </Option>
      <Option name="dataDefinedScalebarMinWidth" type="Map">
       <Option name="active" type="bool" value="true"/>
       <Option name="expression" type="QString" value="case &#xa;when round(map_get(item_variables('Map'), 'map_scale'),0) >=1000000 or @layout_pagewidth &lt;=297 then 10 &#xa;else 50&#xa;end"/>
       <Option name="type" type="int" value="3"/>
