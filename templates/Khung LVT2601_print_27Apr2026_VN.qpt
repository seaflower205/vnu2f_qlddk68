       <Option name="expression" type="QString" value="case&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;= 62370 then &#xa;&#x9;&#x9;&#x9;@layout_pageheight- 6 --A4&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=124740 then &#xa;&#x9;&#x9;&#x9;@layout_pageheight- 4-- A3&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=249480 then &#xa;&#x9;&#x9;&#x9;@layout_pageheight - 9.5 --A2&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight &lt;=499554 then &#xa;&#x9;&#x9;&#x9;@layout_pageheight - 7 --A1&#xa;when  @layout_pagewidth * @layout_pageheight &lt;=999949 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;100000 then @layout_pageheight - 13&#xa;&#x9;&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight >=999949 and &#xa;&#x9;round(map_get(item_variables('Map'), 'map_scale'),0) >=100000 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;=250000 then @layout_pageheight - 12&#xa;&#x9;&#xa;&#x9;when  @layout_pagewidth * @layout_pageheight >=999949 and &#xa;&#x9;round(map_get(item_variables('Map'), 'map_scale'),0) >=250000 and round(map_get(item_variables('Map'), 'map_scale'),0) &lt;1000000 then @layout_pageheight - 7&#xa;&#x9;else @layout_pageheight - 8&#xa;end"/>
