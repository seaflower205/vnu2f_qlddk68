       <Option name="expression" type="QString" value="case &#xa;&#x9;when @project_crs = 'EPSG:4326' and @layout_pagewidth &lt;= 148 then 16 --A5&#xa;&#x9;when @project_crs = 'EPSG:4326' and @layout_pagewidth &lt;=210 then 26 -- A4 &#xa;&#x9;when @project_crs = 'EPSG:4326' and @layout_pagewidth &lt;=297 then 36 -- A3 &#xa;&#x9;when @project_crs = 'EPSG:4326' and @layout_pagewidth >297 then 106 -- A3 &#xa;&#x9;else 0&#xa;end"/>
