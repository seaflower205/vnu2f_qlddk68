        <Option name="active" type="bool" value="true"/>
        <Option name="expression" type="QString" value="case&#xa;&#x9;WHEN @project_crs = 'EPSG:4326' THEN  NULL&#xa;&#x9;when @map_scale &lt;=501 then 50&#xa;&#x9;when @map_scale>501 and @map_scale&lt;=1001 then 100&#xa;&#x9;when @map_scale>1001 and @map_scale&lt;=2001 then 200&#xa;&#x9;when @map_scale>2001 and @map_scale&lt;=5001 then 500&#xa;&#x9;when @map_scale>5001 and @map_scale&lt;=10001 then 1000&#xa;&#x9;when @map_scale>10001 and @map_scale&lt;=15001 then 1500&#xa;&#x9;when @map_scale>15001 and @map_scale&lt;=20001 then 2000&#xa;&#x9;when @map_scale>20001 and @map_scale&lt;=25001 then 2500&#xa;&#x9;when @map_scale>25001 and @map_scale&lt;=50001 then 5000&#xa;&#x9;when @map_scale>50001 and @map_scale&lt;=100001 then 10000&#xa;&#x9;when @map_scale>100001 and @map_scale&lt;=150001 then 15000&#xa;&#x9;when @map_scale>150001 and @map_scale&lt;=200001 then 20000&#xa;&#x9;when @map_scale>200001 and @map_scale&lt;=250001 then 25000&#xa;&#x9;when @map_scale>250001 and @map_scale&lt;=500001 then 50000&#xa;&#x9;when @map_scale>500001 and @map_scale&lt;=1000001 then 100000&#xa;&#x9;when @map_scale>1000001 and @map_scale&lt;=1500001 then 150000&#xa;&#x9;when @map_scale>1500001 and @map_scale&lt;=2000001 then 200000&#xa;&#x9;else 250000&#xa;end"/>
